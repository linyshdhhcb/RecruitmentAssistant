{
  "name": "recruitmentassistant",
  "version": "1.0.0",
  "description": "Desktop recruitment website aggregator built with Electron + React + SQLite.",
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "start": "electron .",
    "build:icon": "node ./scripts/gen-icon.js",
    "build:win": "npm run build:icon && npm run build:renderer && electron-builder --win --x64",
    "fix:dev-env": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-dev-env.ps1",
    "fix:dev-env:run": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-dev-env.ps1 -RunDev"
  },
  "keywords": [
    "electron",
    "react",
    "sqlite",
    "recruitment"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "9.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^6.4.2",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.linyi.recruitmentassistant",
    "productName": "RecruitmentAssistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "企业招聘官网.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RecruitmentAssistant"
    }
  }
}
